{
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/webhooks/credit.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "capitalmotorcars.com"
        }
      ],
      "destination": "https://www.capitalmotorcars.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "express.capitalmotorcars.com"
        }
      ],
      "destination": "https://www.capitalmotorcars.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "nocache"
        }
      ],
      "destination": "https://www.capitalmotorcars.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "jet_blog_ajax"
        }
      ],
      "destination": "https://www.capitalmotorcars.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "fbclid"
        }
      ],
      "destination": "https://www.capitalmotorcars.com/:path*",
      "permanent": true
    },
    {
      "source": "/services/car-detailing",
      "destination": "https://www.capitalmotorcars.com/services/detailing",
      "permanent": true
    },
    {
      "source": "/contact-us",
      "destination": "https://www.capitalmotorcars.com/contact",
      "permanent": true
    },
    {
      "source": "/about-us",
      "destination": "https://www.capitalmotorcars.com/about",
      "permanent": true
    },
    {
      "source": "/services/financing",
      "destination": "https://www.capitalmotorcars.com/services/credit",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "^/mazda-cx-50-reliability/?$",
      "status": 410
    },
    {
      "src": "^/category/(.*)$",
      "status": 410
    },
    {
      "src": "^/style/(.*)$",
      "status": 410
    },
    {
      "src": "^/makes/(.*)$",
      "status": 410
    },
    {
      "src": "^/types-of-transport/(.*)$",
      "status": 410
    },
    {
      "src": "^/autos/(.*)$",
      "status": 410
    },
    {
      "src": "^/brand/page/[0-9]+/?$",
      "status": 410
    },
    {
      "src": "^/.+/[2-9][0-9]*/?$",
      "status": 410
    },
    {
      "src": "^/sitemap/?$",
      "status": 410
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
